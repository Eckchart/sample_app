<% provide(:title, "Edit user") %>
<% provide(:button_text, "Save changes") %>
<h1>Update your profile</h1>

<div class="row">
    <div class="col-md-6 col-md-offset-3">
        <%= render 'form' %>

        <div class="gravatar_edit">
            <%= gravatar_for @user %>

            <%# `target="_blank"` forces the browser to open
            <%#  the page in a new window or tab;
            <%# `rel="noopener"` eliminates the risk of the target site
            <%# introducing malicious content (such as a phishing page). %>
            <a href="https://gravatar.com/emails" target="_blank" rel="noopener">Change</a> 
        </div>
    </div>
</div>
